generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ─────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  slackUserId    String  @unique
  slackEmail     String  @unique
  slackName      String?
  slackAvatarUrl String?

  // SFDC per-user OAuth (tokens AES-256-GCM encrypted at rest)
  sfdcUserId       String?
  sfdcInstanceUrl  String?
  sfdcAccessToken  String?
  sfdcRefreshToken String?
  sfdcTokenExpiresAt DateTime?
  sfdcConnectedAt  DateTime?

  isRevOps Boolean @default(false)

  notifications Notification[]
  nudgesReceived NudgeLog[]     @relation("NudgeTarget")
  nudgesSent     NudgeLog[]     @relation("NudgeSender")

  @@map("users")
}

// ─── Admin Config ────────────────────────────────────────────────────────────

// Key/value store for global settings (stored as JSON strings)
model AppSetting {
  key       String   @id
  value     String   // JSON-encoded
  updatedAt DateTime @updatedAt
  updatedBy String?  // RevOps user email

  @@map("app_settings")
}

// ─── Stall Rules ─────────────────────────────────────────────────────────────

model StallRule {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name    String
  enabled Boolean @default(true)

  // Thresholds (either or both can be set)
  dealAgeThresholdDays      Int? // total opp age in days
  stageDurationThresholdDays Int? // days in current stage

  // Filters (null = applies to all)
  filterStages      String[] // SFDC stage names
  filterOppTypes    String[] // e.g. ["New Business", "Renewal", "Amendment"]
  filterSegments    String[] // e.g. ["Enterprise", "Mid-Market", "SMB"]
  filterOwnerIds    String[] // SFDC user IDs (empty = all)

  // Also flag if no Gong activity in this many days
  gongInactivityDays Int?

  // Also flag if single-threaded (only 1 contact on Gong calls)
  flagSingleThreaded Boolean @default(false)

  // Also flag on Gong red flags
  flagGongRedFlags Boolean @default(false)

  notifications Notification[]

  @@map("stall_rules")
}

// ─── Stall Thresholds by Stage ───────────────────────────────────────────────

model StallThresholdByStage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stageName       String
  opportunityType String  @default("All") // "All" = applies to all types
  enabled         Boolean @default(true)

  // Thresholds — null means "don't check this"
  stageDurationThresholdDays Int? // flag if Stage_Duration_current__c >= this
  dealAgeThresholdDays       Int? // flag if Opportunity_Age__c >= this

  @@unique([stageName, opportunityType])
  @@map("stall_thresholds_by_stage")
}

// ─── MEDDPICC Config ─────────────────────────────────────────────────────────

// Maps each SFDC stage to which MEDDPICC fields are required
model MeddpiccStageRequirement {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stageName       String
  opportunityType String  @default("All") // "All" = applies to all types
  enabled         Boolean @default(true)

  // Which MEDDPICCP components are required at this stage
  requireMetrics           Boolean @default(false)
  requireEconomicBuyer     Boolean @default(false)
  requireDecisionCriteria  Boolean @default(false)
  requireDecisionProcess   Boolean @default(false)
  requireIdentifyPain      Boolean @default(false)
  requireChampion          Boolean @default(false)
  requireCompetition       Boolean @default(false)
  requirePaperProcess      Boolean @default(false)

  // SFDC field API names (Uberall org)
  sfdcFieldMetrics          String @default("M_Metrics__c")
  sfdcFieldEconomicBuyer    String @default("E_Economic_buyer__c")
  sfdcFieldDecisionCriteria String @default("DC_Decision_Criteria__c")
  sfdcFieldDecisionProcess  String @default("DP_Decision_Process__c")
  sfdcFieldIdentifyPain     String @default("I_Identify_Pain__c")
  sfdcFieldChampion         String @default("Ch_Champion__c")
  sfdcFieldCompetition      String @default("Co_Competition_New__c")
  sfdcFieldPaperProcess     String @default("P_Paperwork__c")

  // BANT fields
  requireBudget    Boolean @default(false)
  requireAuthority Boolean @default(false)
  requireNeed      Boolean @default(false)
  requireTiming    Boolean @default(false)

  sfdcFieldBudget    String @default("Budget_Details__c")
  sfdcFieldAuthority String @default("Authority_Details__c")
  sfdcFieldNeed      String @default("Need_Details__c")
  sfdcFieldTiming    String @default("Timing_Details__c")

  @@unique([stageName, opportunityType])
  @@map("meddpicc_stage_requirements")
}

// ─── Close Date Risk Rules ───────────────────────────────────────────────────

// Flag opps that are too close to their close date for the stage they're in
model CloseDateRiskRule {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stageName       String
  opportunityType String  @default("All")
  daysThreshold   Int                       // alert if close date is within this many days
  enabled         Boolean @default(true)

  @@unique([stageName, opportunityType])
  @@map("close_date_risk_rules")
}

// ─── Stage Mismatch Rules ────────────────────────────────────────────────────

model StageMismatchRule {
  id        String   @id @default(cuid())
  name      String
  keywords  String[]
  stages    String[]
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("stage_mismatch_rules")
}

// ─── Notifications ───────────────────────────────────────────────────────────

enum AlertType {
  PAST_DUE_INITIAL
  PAST_DUE_AMENDMENT
  PAST_DUE_RENEWAL
  STALLED
  MEDDPICC_MISSING
  NEXT_STEP_MISSING
  CLOSE_DATE_RISK
  STAGE_MISMATCH
}

enum NotificationStatus {
  SENT
  SNOOZED
  RESOLVED
  DISMISSED
  FAILED
}

model Notification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  opportunityId   String // SFDC Opportunity ID
  opportunityName String
  ownerId         String
  owner           User   @relation(fields: [ownerId], references: [id])

  alertType    AlertType
  alertDetails Json    // type-specific payload (missing fields, days stalled, etc.)

  // Who was notified: "rep" (deal owner) or "manager" (owner's manager)
  recipientType String @default("rep")

  // Slack message tracking
  slackMessageTs  String?
  slackChannelId  String?

  status       NotificationStatus @default(SENT)
  snoozedUntil DateTime?
  resolvedAt   DateTime?
  sentAt       DateTime           @default(now())

  // If triggered by a stall rule
  stallRuleId String?
  stallRule   StallRule? @relation(fields: [stallRuleId], references: [id])

  // SFDC update tracking (when user updates from Slack)
  sfdcUpdatedAt    DateTime?
  sfdcUpdateFields Json?     // what was updated

  @@index([opportunityId])
  @@index([ownerId])
  @@index([alertType])
  @@index([status])
  @@map("notifications")
}

// ─── Nudge Log ───────────────────────────────────────────────────────────────

model NudgeLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  opportunityId   String
  opportunityName String

  nudgedById String
  nudgedBy   User   @relation("NudgeSender", fields: [nudgedById], references: [id])

  targetUserId String
  targetUser   User   @relation("NudgeTarget", fields: [targetUserId], references: [id])

  alertType      AlertType
  customMessage  String?
  slackMessageTs String?

  @@map("nudge_logs")
}

// ─── Flag Snapshots ──────────────────────────────────────────────────────────

model FlagSnapshot {
  id            String    @id @default(cuid())
  runAt         DateTime
  opportunityId String
  alertType     AlertType
  ownerEmail    String
  ownerName     String?
  managerEmail  String?
  managerName   String?

  @@index([runAt])
  @@index([ownerEmail])
  @@index([managerEmail])
  @@map("flag_snapshots")
}

// ─── Admin Users ─────────────────────────────────────────────────────────────

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Admin Sessions ──────────────────────────────────────────────────────────

model AdminSession {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  expiresAt DateTime

  email     String
  tokenHash String @unique

  @@map("admin_sessions")
}
