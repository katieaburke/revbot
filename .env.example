# Database
DATABASE_URL="postgresql://pipeline:pipeline@localhost:5432/pipeline_nudge"

# Redis
REDIS_URL="redis://localhost:6379"

# App
APP_URL="http://localhost:3001"
PORT=3001
NODE_ENV=development

# Encryption key for storing OAuth tokens (32 bytes hex = 64 chars)
ENCRYPTION_KEY="your-32-byte-hex-encryption-key-here-replace-me"

# Salesforce Connected App
SFDC_CLIENT_ID="your-sfdc-consumer-key"
SFDC_CLIENT_SECRET="your-sfdc-consumer-secret"
SFDC_REDIRECT_URI="http://localhost:3001/auth/sfdc/callback"
# Use login.salesforce.com for prod, test.salesforce.com for sandbox
SFDC_LOGIN_URL="https://login.salesforce.com"

# Slack App
SLACK_BOT_TOKEN="xoxb-your-bot-token"
SLACK_SIGNING_SECRET="your-signing-secret"
SLACK_APP_TOKEN="xapp-your-app-token"  # For Socket Mode (dev)

# Gong API
GONG_ACCESS_KEY="your-gong-access-key"
GONG_ACCESS_SECRET="your-gong-access-secret"

# Admin auth (simple JWT for RevOps web UI)
JWT_SECRET="your-jwt-secret-replace-me"
ADMIN_EMAIL="revops@yourcompany.com"
ADMIN_PASSWORD_HASH=""  # bcrypt hash, generated on first run
